{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"allowImportingTsExtensions": true,
		"lib": ["ES2022"],
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"resolveJsonModule": true,

		"noEmit": true,
		"types": ["node"],
		"baseUrl": "."
	},
	"include": ["packages/*/**/*.ts", "test/**/*.ts", "vitest.config.ts"],
	"exclude": [
		"**/node_modules/**",
		"**/.pi/**"
	]
}
